{
  "$schema": "https://opencode.ai/config.json",
  "snapshot": false,
  "permission": {
    "bash": { "*": "allow" },
    "edit": "allow",
    "read": "allow"
  },
  "agent": {
    "build": { "model": "opencode/deepseek-v4-flash-free" },
    "plan": { "model": "opencode/deepseek-v4-flash-free" },
    "general": { "model": "opencode/deepseek-v4-flash-free" },
    "explore": { "model": "opencode/deepseek-v4-flash-free" },
    "scout": { "model": "opencode/deepseek-v4-flash-free" }
  },
  "mcp": {
    "fastcontext": {
      "type": "remote",
      "url": "http://127.0.0.1:18950/sse",
      "enabled": true,
      "timeout": 120000
    }
  },
  "provider": {
    "openai": {
      "options": {
        "headerTimeout": 60000,
        "timeout": 600000
      }
    }
  }
}
