{
  "$schema": "https://opencode.ai/config.json",
  "snapshot": false,
  "permission": {
    "bash": { "*": "allow" },
    "edit": "allow",
    "read": "allow"
  },
  "agent": {
    "build": { "model": "opencode/deepseek-v4-flash-free" },
    "plan": { "model": "opencode/deepseek-v4-flash-free" },
    "general": { "model": "opencode/deepseek-v4-flash-free" },
    "explore": { "model": "opencode/deepseek-v4-flash-free" },
    "scout": { "model": "opencode/deepseek-v4-flash-free" }
  },
  "mcp": {
    "fastcontext": {
      "type": "local",
      "command": ["uv", "run", "--directory", "/home/a/projects/ai/side-chick", "fastcontext", "mcp"],
      "enabled": true,
      "env": {
        "MODEL": "BhupendraA/FastContext-1.0-4B-RL-Q4_K_M-GGUF:latest",
        "BASE_URL": "http://127.0.0.1:11434/v1",
        "API_KEY": "ollama"
      }
    }
  },
  "provider": {
    "openai": {
      "options": {
        "headerTimeout": 60000,
        "timeout": 600000
      }
    }
  }
}
